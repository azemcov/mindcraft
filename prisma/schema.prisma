generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
}
// ─────────────────────────────────────────────
// AUTH (NextAuth.js)
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// ПОЛЬЗОВАТЕЛЬ
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique           // [+] обязательный
  name         String?
  position     String?
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())

  ownedGroups  Group[]        @relation("GroupOwner")
  memberships  GroupMember[]
  createdTests Test[]         @relation("TestAuthor")
  submissions  Submission[]
  accounts     Account[]
  sessions     Session[]
}

// ─────────────────────────────────────────────
// ГРУППА
// ─────────────────────────────────────────────

enum GroupAccess {
  OPEN      // любой может вступить
  BY_INVITE // только по приглашению
}

enum GroupRole {
  MODERATOR // [~] убран OWNER — владелец уже хранится в Group.ownerId
  MEMBER
}

model Group {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  access    GroupAccess @default(OPEN)
  createdAt DateTime    @default(now())

  ownerId  String
  owner    User            @relation("GroupOwner", fields: [ownerId], references: [id])
  members  GroupMember[]
  tests    TestAssignment[]
}

model GroupMember {
  id      String    @id @default(cuid())
  role    GroupRole @default(MEMBER)

  userId  String
  user    User  @relation(fields: [userId], references: [id])

  groupId String
  group   Group @relation(fields: [groupId], references: [id])

  emailNotifications Boolean @default(true)  // студент может отписаться от уведомлений группы

  @@unique([userId, groupId])
}

// ─────────────────────────────────────────────
// ТЕСТ
// ─────────────────────────────────────────────

model Test {
  id        String   @id @default(cuid())
  title     String
  isDraft   Boolean  @default(true)       // [+] черновик / опубликован
  autoCheck Boolean  @default(true)
  timeLimit Int?                          // минуты
  maxScore  Float    @default(0)          // [+] денормализованный итоговый балл
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  author   User   @relation("TestAuthor", fields: [authorId], references: [id])

  questions   Question[]
  assignments TestAssignment[]
  submissions Submission[]                // [+] обратная связь
}

// ─────────────────────────────────────────────
// НАЗНАЧЕНИЕ ТЕСТА В ГРУППУ
// ─────────────────────────────────────────────

model TestAssignment {
  id         String    @id @default(cuid())
  assignedAt DateTime  @default(now())

  availableFrom DateTime?
  availableTo   DateTime?

  groupId String
  group   Group  @relation(fields: [groupId], references: [id])

  testId String
  test   Test   @relation(fields: [testId], references: [id])

  submissions Submission[]                // [+] обратная связь

  notifyMembers Boolean   @default(true)  // слать ли уведомления вообще
  notifiedAt    DateTime?                 // когда задача-уведомлятор уже отработала

  @@unique([groupId, testId])
}

// ─────────────────────────────────────────────
// ВОПРОС
// ─────────────────────────────────────────────

enum QuestionType {
  TEXT
  IMAGE
  AUDIO
}

model Question {
  id               String       @id @default(cuid())
  order            Int
  questionType     QuestionType
  answerType       QuestionType
  isMultipleAnswer Boolean      @default(false)
  text             String?
  imageUrl         String?
  audioUrl         String?
  points           Float        @default(1)

  testId  String
  test    Test           @relation(fields: [testId], references: [id], onDelete: Cascade)
  options AnswerOption[]
  answers SubmissionAnswer[]
}

model AnswerOption {
  id        String  @id @default(cuid())
  order     Int
  text      String?
  imageUrl  String?
  audioUrl  String?
  isCorrect Boolean @default(false)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  selectedIn SubmissionAnswer[] @relation("SelectedOptions")
}

// ─────────────────────────────────────────────
// ПОПЫТКА (SUBMISSION)
// ─────────────────────────────────────────────

enum SubmissionStatus {               // [+] статус попытки
  IN_PROGRESS                         // студент ещё проходит
  SUBMITTED                           // сдано, ожидает проверки
  GRADED                              // проверено, выставлена оценка
}

model Submission {
  id        String           @id @default(cuid())
  status    SubmissionStatus @default(IN_PROGRESS) // [+]
  score     Float?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  testId String
  test   Test   @relation(fields: [testId], references: [id])

  assignmentId String?                              // [+] по какому назначению сдаётся
  assignment   TestAssignment? @relation(fields: [assignmentId], references: [id])

  startedAt DateTime         @default(now()) // старт прохождения теста
  submittedAt DateTime?  // момент отправки
  updatedAt   DateTime   @updatedAt  // последнее изменение статуса/оценки

  answers SubmissionAnswer[]
}

// ─────────────────────────────────────────────
// ОТВЕТЫ СТУДЕНТА
// ─────────────────────────────────────────────

model SubmissionAnswer {
  id           String @id @default(cuid())

  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id])

  selectedOptions AnswerOption[] @relation("SelectedOptions")

  textAnswer  String?
  imageUrl    String?            // [+] для answerType = IMAGE
  audioUrl    String?            // [+] для answerType = AUDIO
}
